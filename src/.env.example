# Configurações do servidor
PORT=3000

# Chave secreta para autenticação da API (troque por uma string aleatória segura)
API_SECRET_KEY=sua_chave_secreta_aqui_1234

# Seu número de WhatsApp (com código do país, sem + ou espaços)
# Exemplo: 5585999998888
MEU_NUMERO_WHATSAPP=5584988812008

# Banco de dados (SQLite por padrão, não precisa alterar)
DB_PATH=./finbot.db